<mujoco model="simple_teleop_arm">
    <compiler angle="degree" coordinate="local"/>
    <option timestep="0.002" integrator="RK4">
        <flag energy="enable"/>
    </option>
    
    <default>
        <joint damping="0.1" armature="0.01" limited="true"/>
        <geom condim="3" material="arm_material"/>
    </default>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="grid" type="2d" builtin="checker" rgb1="0.1 0.1 0.1" rgb2="0.15 0.15 0.15" width="512" height="512" mark="edge" markrgb="0.3 0.3 0.3"/>
        <material name="grid_material" texture="grid" texrepeat="2 2" texuniform="true"/>
        <material name="arm_material" rgba="0.8 0.8 0.8 1.0"/>
        <material name="joint_material" rgba="0.2 0.2 0.2 1.0"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true" castshadow="true"/>
        <geom name="floor" type="plane" size="2 2 0.1" material="grid_material"/>

        <!-- Robot Base -->
        <body name="base" pos="0 0 0.1">
            <geom name="base_geom" type="cylinder" size="0.08 0.1" material="joint_material"/>
            
            <!-- Link 1: Shoulder Yaw -->
            <body name="link1" pos="0 0 0.1">
                <joint name="joint1" type="hinge" axis="0 0 1" range="-180 180"/>
                <geom name="link1_geom" type="cylinder" size="0.05 0.1" pos="0 0 0.1"/>
                
                <!-- Link 2: Shoulder Pitch -->
                <body name="link2" pos="0 0 0.2">
                    <joint name="joint2" type="hinge" axis="0 1 0" range="-90 90"/>
                    <geom name="link2_geom" type="box" size="0.04 0.04 0.15" pos="0 0 0.15"/>
                    
                    <!-- Link 3: Elbow Pitch -->
                    <body name="link3" pos="0 0 0.3">
                        <joint name="joint3" type="hinge" axis="0 1 0" range="-150 150"/>
                        <geom name="link3_geom" type="box" size="0.035 0.035 0.15" pos="0 0 0.15"/>
                        
                        <!-- Link 4: Wrist Roll -->
                        <body name="link4" pos="0 0 0.3">
                            <joint name="joint4" type="hinge" axis="0 0 1" range="-180 180"/>
                            <geom name="link4_geom" type="cylinder" size="0.03 0.05" pos="0 0 0.05" material="joint_material"/>
                            
                            <!-- Link 5: Wrist Pitch -->
                            <body name="link5" pos="0 0 0.1">
                                <joint name="joint5" type="hinge" axis="0 1 0" range="-120 120"/>
                                <geom name="link5_geom" type="box" size="0.025 0.025 0.08" pos="0 0 0.08"/>
                                
                                <!-- End Effector -->
                                <body name="end_effector" pos="0 0 0.16">
                                    <joint name="joint6" type="hinge" axis="0 0 1" range="-180 180"/>
                                    <geom name="ee_geom" type="sphere" size="0.03" rgba="1 0.2 0.2 1"/>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>

        <!-- Mocap Target (Controlled by hand tracker or mock sinus path) -->
        <body name="mocap_target" mocap="true" pos="0.0 0.0 1.26">
            <geom name="mocap_geom" type="sphere" size="0.03" rgba="0 1 0 0.5" contype="0" conaffinity="0"/>
            <geom type="cylinder" size="0.003" fromto="0 0 0 0.08 0 0" rgba="1 0 0 0.8" contype="0" conaffinity="0"/>
            <geom type="cylinder" size="0.003" fromto="0 0 0 0 0.08 0" rgba="0 1 0 0.8" contype="0" conaffinity="0"/>
            <geom type="cylinder" size="0.003" fromto="0 0 0 0 0 0.08" rgba="0 0 1 0.8" contype="0" conaffinity="0"/>
        </body>
    </worldbody>

    <!-- Weld constraint to drag end_effector with mocap_target -->
    <equality>
        <weld name="teleop_weld" body1="end_effector" body2="mocap_target"/>
    </equality>
</mujoco>
